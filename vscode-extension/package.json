{
  "name": "helloworld",
  "displayName": "HelloWorld",
  "description": "HelloWorld VS Code extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "vsce": {
    "ignoreFile": ".vscodeignore"
  },
  "activationEvents": [
    "onCommand:extension.openTsConcat",
    "onCommand:extension.openSwiftConcat",
    "onCommand:extension.openSourceView.ts",
    "onCommand:extension.openSourceView.swift",
    "onCommand:extension.openSourceView.c"
  ],
  "contributes": {
    "commands": [
      {
        "command": "helloworld.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "extension.openTsConcat",
        "title": "Open TS Concat View"
      },
      {
        "command": "extension.openSwiftConcat",
        "title": "Open Swift Concat View"
      },
      {
        "command": "extension.openSourceView.ts",
        "title": "TypeScript"
      },
      {
        "command": "extension.openSourceView.swift",
        "title": "Swift"
      },
      {
        "command": "extension.openSourceView.c",
        "title": "C / C Header"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "extension.openSourceViewSubmenu",
          "when": "explorerResourceIsFolder",
          "group": "navigation@1"
        }
      ],
      "extension.openSourceViewSubmenu": [
        {
          "command": "extension.openSourceView.ts"
        },
        {
          "command": "extension.openSourceView.swift"
        },
        {
          "command": "extension.openSourceView.c"
        }
      ]
    },
    "submenus": [
      {
        "id": "extension.openSourceViewSubmenu",
        "label": "Open Source View"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
